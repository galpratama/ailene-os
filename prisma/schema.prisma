generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Mirrors docs/db/ailene-os-ddl.sql.

////////////////////
// Enumerations   //
////////////////////

enum StatusEnum {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("status_enum")
}

// Enumeration for the User model

enum OccupationEnum {
  EMPLOYEE     @map("employee")
  ENTREPRENEUR @map("entrepreneur")
  STUDENT      @map("student")
  FREELANCE    @map("freelance")
  MILITARY     @map("military")
  UNEMPLOYED   @map("unemployed")

  @@map("occupation_enum")
}

// Enumeration for the B2BPipeline model (b2b_*)

enum B2BProductEnum {
  SPONSORSHIP           @map("sponsorship")
  CORPORATE_TRAINING    @map("corporate_training")
  CORPORATE_AI_TRAINING @map("corporate_ai_training")

  @@map("b2b_product_enum")
}

enum B2BSourceEnum {
  SOCIAL_MEDIA     @map("social_media")
  FOUNDER_NETWORK  @map("founder_network")
  EVENT_CONFERENCE @map("event_conference")
  REFERRAL_PARTNER @map("referral_partner")
  REFERRAL_CLIENT  @map("referral_client")
  WEBSITE          @map("website")

  @@map("b2b_source_enum")
}

enum B2BStageEnum {
  LEAD_IDENTIFIED @map("lead_identified")
  CONTACTED       @map("contacted")
  NEGOTIATION     @map("negotiation")
  VERBAL_COMMIT   @map("verbal_commit")
  CLOSED_WON      @map("closed_won")
  CLOSED_LOST     @map("closed_lost")
  ON_HOLD         @map("on_hold")

  @@map("b2b_stage_enum")
}

enum B2BProbabilityStatusEnum {
  COLD @map("cold")
  WARM @map("warm")
  HOT  @map("hot")

  @@map("b2b_probability_status_enum")
}

// Enumeration for the B2BAction model (b2ba_*)

enum B2BActionStatusEnum {
  TO_DO       @map("to_do")
  IN_PROGRESS @map("in_progress")
  REVIEW      @map("review")
  DONE        @map("done")

  @@map("b2ba_status_enum")
}

enum B2BActionPriorityEnum {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
  URGENT @map("urgent")

  @@map("b2ba_priority_enum")
}

// Enumeration for the TrainerPool models (trainer_*, trnsc_*, trncert_*, trna_*)

enum TrainerLevelEnum {
  APPRENTICE @map("apprentice")
  CERTIFIED  @map("certified")
  SENIOR     @map("senior")
  LEAD       @map("lead")

  @@map("trainer_level_enum")
}

enum TrainerStatusEnum {
  CANDIDATE @map("candidate")
  CERTIFIED @map("certified")
  ACTIVE    @map("active")
  REMEDIAL  @map("remedial")
  INACTIVE  @map("inactive")

  @@map("trainer_status_enum")
}

enum TrainerSourceEnum {
  AI_COMMUNITY           @map("ai_community")
  TOP_ALUMNI             @map("top_alumni")
  DOMAIN_PRACTITIONER    @map("domain_practitioner")
  TRAINER_NETWORK        @map("trainer_network")
  CORPORATE_PRACTITIONER @map("corporate_practitioner")
  INTERNAL_REFERRAL      @map("internal_referral")

  @@map("trainer_source_enum")
}

enum TrainerScreeningStepEnum {
  APPLICATION_REVIEW @map("application_review")
  INTERVIEW          @map("interview")
  TEACHING_DEMO      @map("teaching_demo")
  PRACTICAL_TEST     @map("practical_test")
  REFERENCE_CHECK    @map("reference_check")

  @@map("trnsc_step_enum")
}

enum TrainerScreeningStatusEnum {
  PENDING @map("pending")
  PASSED  @map("passed")
  FAILED  @map("failed")
  SKIPPED @map("skipped")

  @@map("trnsc_status_enum")
}

enum TrainerCertificationStepEnum {
  ORIENTATION            @map("orientation")
  MATERIAL_MASTERY       @map("material_mastery")
  SHADOWING              @map("shadowing")
  CO_TRAINING            @map("co_training")
  SOLO_OBSERVED_DELIVERY @map("solo_observed_delivery")
  CERTIFICATION_DECISION @map("certification_decision")

  @@map("trncert_step_enum")
}

enum TrainerCertificationStatusEnum {
  NOT_STARTED @map("not_started")
  IN_PROGRESS @map("in_progress")
  PASSED      @map("passed")
  FAILED      @map("failed")

  @@map("trncert_status_enum")
}

enum TrainerAvailabilityStatusEnum {
  AVAILABLE   @map("available")
  LIMITED     @map("limited")
  UNAVAILABLE @map("unavailable")

  @@map("trainer_availability_status_enum")
}

enum TrainerAssignmentRoleEnum {
  LEAD       @map("lead")
  ASSISTANT  @map("assistant")
  CO_TRAINER @map("co_trainer")
  SPECIALIST @map("specialist")

  @@map("trna_role_enum")
}

// Enumeration for the B2B Class/Session models (b2bc_*)

enum B2BClassDifficultyEnum {
  BEGINNER @map("beginner")
  ADVANCED @map("advanced")

  @@map("b2bc_difficulty_enum")
}

enum B2BClassSessionStatusEnum {
  DRAFT  @map("draft")
  OPEN   @map("open")
  CLOSED @map("closed")

  @@map("b2bc_session_status_enum")
}

enum TrainerApplicationStatusEnum {
  APPLIED     @map("applied")
  SHORTLISTED @map("shortlisted")
  REJECTED    @map("rejected")
  SELECTED    @map("selected")

  @@map("trainer_application_status_enum")
}

enum TrainerLevelOverrideEnum {
  JUNIOR @map("junior")
  SENIOR @map("senior")

  @@map("trainer_level_override_enum")
}

enum TrainerSessionNotificationStatusEnum {
  SENT   @map("sent")
  FAILED @map("failed")

  @@map("trainer_session_notification_status_enum")
}

////////////
// Models //
////////////

// Lookup tables

model Industry {
  id            Int          @id @default(autoincrement()) @db.SmallInt
  industry_name String       @unique @db.VarChar()
  created_at    DateTime     @default(now()) @db.Timestamptz()
  b2b_companies B2BCompany[]

  @@map("industries")
}

model Role {
  id         Int      @id @default(autoincrement()) @db.SmallInt
  name       String   @unique @db.VarChar()
  permission Int      @db.SmallInt
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()
  users      User[]

  @@map("roles")
}

model PhoneCountryCode {
  id           Int       @id @default(autoincrement()) @db.SmallInt
  country_name String    @db.VarChar()
  phone_code   String    @unique @db.VarChar()
  emoji        String    @db.VarChar()
  icon         String?   @db.VarChar()
  users        User[]
  trainers     Trainer[]

  @@map("phone_country_codes")
}

model TrainerSpecialization {
  id                  Int                        @id @default(autoincrement()) @db.SmallInt
  specialization_name String                     @unique @db.VarChar()
  created_at          DateTime                   @default(now()) @db.Timestamptz()
  trainers            TrainerSpecializationMap[]

  @@map("trainer_specializations")
}

// User data

model User {
  id                            String                     @id @default(uuid()) @db.Uuid
  full_name                     String                     @db.VarChar()
  email                         String                     @unique @db.VarChar()
  phone_country                 PhoneCountryCode?          @relation(fields: [phone_country_id], references: [id])
  phone_country_id              Int?                       @db.SmallInt
  phone_number                  String?                    @db.VarChar()
  avatar                        String?                    @db.VarChar()
  role                          Role                       @relation(fields: [role_id], references: [id])
  role_id                       Int                        @default(3) @db.SmallInt // General User
  status                        StatusEnum                 @default(ACTIVE)
  date_of_birth                 DateTime?                  @db.Date
  occupation                    OccupationEnum?
  created_at                    DateTime                   @default(now()) @db.Timestamptz()
  updated_at                    DateTime                   @default(now()) @updatedAt @db.Timestamptz()
  last_login                    DateTime                   @default(now()) @updatedAt @db.Timestamptz()
  deleted_at                    DateTime?                  @db.Timestamptz()
  tokens                        Token[]
  b2b_pipelines                 B2BPipeline[]
  b2b_actions                   B2BAction[]
  trainer_profiles              Trainer[]                  @relation("TrainerUser")
  trainer_referrals             Trainer[]                  @relation("TrainerReferrer")
  trainer_scores                TrainerScreeningScore[]    @relation("TrainerScreeningScorer")
  trainer_certifications        TrainerCertificationStep[] @relation("TrainerCertificationEvaluator")
  trainer_evaluations           TrainerEvaluation[]        @relation("TrainerEvaluationReviewer")
  trainer_level_overrides_set   Trainer[]                  @relation("TrainerLevelOverrideSetter")
  b2b_classes_created           B2BClass[]                 @relation("B2BClassCreator")
  trainer_applications_reviewed TrainerApplication[]       @relation("TrainerApplicationReviewer")

  @@map("users")
}

model Token {
  id         Int      @id @default(autoincrement()) @db.Integer
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String   @db.Uuid
  is_active  Boolean  @default(false) @db.Boolean
  token      String   @unique @db.Text
  created_at DateTime @default(now()) @db.Timestamptz()

  @@map("tokens")
}

// B2B Sales Pipeline

model B2BCompany {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar()
  industry      Industry      @relation(fields: [industry_id], references: [id])
  industry_id   Int           @db.SmallInt
  pic_name      String?       @db.VarChar()
  pic_job_title String?       @db.VarChar()
  pic_wa        String?       @db.VarChar()
  pic_email     String?       @db.VarChar()
  created_at    DateTime      @default(now()) @db.Timestamptz()
  updated_at    DateTime      @default(now()) @updatedAt @db.Timestamptz()
  pipelines     B2BPipeline[]

  @@map("b2b_company")
}

model B2BPipeline {
  id                  Int                      @id @default(autoincrement())
  name                String                   @db.VarChar()
  company             B2BCompany               @relation(fields: [company_id], references: [id])
  company_id          Int
  product             B2BProductEnum
  source              B2BSourceEnum?
  stage               B2BStageEnum             @default(LEAD_IDENTIFIED)
  probability         Int                      @default(0) @db.SmallInt
  probability_status  B2BProbabilityStatusEnum @default(COLD)
  project_value       Decimal                  @default(0) @db.Decimal(15, 2)
  project_start_month DateTime?                @db.Date
  project_end_month   DateTime?                @db.Date
  owner               User                     @relation(fields: [owner_id], references: [id])
  owner_id            String                   @db.Uuid
  created_at          DateTime                 @default(now()) @db.Timestamptz()
  updated_at          DateTime                 @default(now()) @updatedAt @db.Timestamptz()
  actions             B2BAction[]
  trainer_assignments TrainerAssignment[]
  classes             B2BClass[]

  @@map("b2b_pipeline")
}

model B2BAction {
  id          Int                   @id @default(autoincrement())
  pipeline    B2BPipeline           @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  pipeline_id Int
  name        String                @db.VarChar()
  summary     String?               @db.Text
  status      B2BActionStatusEnum   @default(TO_DO)
  priority    B2BActionPriorityEnum @default(MEDIUM)
  due_date    DateTime?             @db.Date
  assignee    User?                 @relation(fields: [assignee_id], references: [id], onDelete: SetNull)
  assignee_id String?               @db.Uuid
  created_at  DateTime              @default(now()) @db.Timestamptz()
  updated_at  DateTime              @default(now()) @updatedAt @db.Timestamptz()

  @@map("b2b_actions")
}

// Trainer Pool

model Trainer {
  id                    String                       @id @default(uuid()) @db.Uuid
  full_name             String                       @db.VarChar()
  email                 String                       @unique @db.VarChar()
  phone_country         PhoneCountryCode?            @relation(fields: [phone_country_id], references: [id])
  phone_country_id      Int?                         @db.SmallInt
  phone_number          String?                      @db.VarChar()
  source                TrainerSourceEnum?
  level                 TrainerLevelEnum             @default(APPRENTICE)
  status                TrainerStatusEnum            @default(CANDIDATE)
  user                  User?                        @relation("TrainerUser", fields: [user_id], references: [id])
  user_id               String?                      @db.Uuid
  referrer              User?                        @relation("TrainerReferrer", fields: [referred_by], references: [id])
  referred_by           String?                      @db.Uuid
  notes                 String?                      @db.Text
  ai_experience_years   Int                          @default(0) @db.SmallInt
  level_override        TrainerLevelOverrideEnum?
  level_override_setter User?                        @relation("TrainerLevelOverrideSetter", fields: [level_override_set_by], references: [id])
  level_override_set_by String?                      @db.Uuid
  level_override_set_at DateTime?                    @db.Timestamptz()
  created_at            DateTime                     @default(now()) @db.Timestamptz()
  updated_at            DateTime                     @default(now()) @updatedAt @db.Timestamptz()
  deleted_at            DateTime?                    @db.Timestamptz()
  specializations       TrainerSpecializationMap[]
  screening_steps       TrainerScreeningStep[]
  screening_score       TrainerScreeningScore?
  certification_steps   TrainerCertificationStep[]
  availabilities        TrainerAvailability[]
  assignments           TrainerAssignment[]
  evaluations           TrainerEvaluation[]
  applications          TrainerApplication[]
  session_notifications TrainerSessionNotification[]

  @@map("trainers")
}

model TrainerSpecializationMap {
  trainer           Trainer               @relation(fields: [trainer_id], references: [id], onDelete: Cascade)
  trainer_id        String                @db.Uuid
  specialization    TrainerSpecialization @relation(fields: [specialization_id], references: [id], onDelete: Cascade)
  specialization_id Int                   @db.SmallInt

  @@id([trainer_id, specialization_id])
  @@map("trainer_specialization_map")
}

model TrainerScreeningStep {
  id           Int                        @id @default(autoincrement())
  trainer      Trainer                    @relation(fields: [trainer_id], references: [id], onDelete: Cascade)
  trainer_id   String                     @db.Uuid
  step         TrainerScreeningStepEnum
  status       TrainerScreeningStatusEnum @default(PENDING)
  notes        String?                    @db.Text
  completed_at DateTime?                  @db.Timestamptz()
  created_at   DateTime                   @default(now()) @db.Timestamptz()
  updated_at   DateTime                   @default(now()) @updatedAt @db.Timestamptz()

  @@unique([trainer_id, step])
  @@map("trainer_screening_steps")
}

model TrainerScreeningScore {
  id                       Int       @id @default(autoincrement())
  trainer                  Trainer   @relation(fields: [trainer_id], references: [id], onDelete: Cascade)
  trainer_id               String    @unique @db.Uuid
  ai_hands_on_score        Int       @default(0) @db.SmallInt
  facilitation_score       Int       @default(0) @db.SmallInt
  domain_credibility_score Int       @default(0) @db.SmallInt
  communication_score      Int       @default(0) @db.SmallInt
  reliability_score        Int       @default(0) @db.SmallInt
  total_score              Int       @default(0) @db.SmallInt
  scorer                   User?     @relation("TrainerScreeningScorer", fields: [scored_by], references: [id])
  scored_by                String?   @db.Uuid
  scored_at                DateTime? @db.Timestamptz()
  created_at               DateTime  @default(now()) @db.Timestamptz()
  updated_at               DateTime  @default(now()) @updatedAt @db.Timestamptz()

  @@map("trainer_screening_scores")
}

model TrainerCertificationStep {
  id                 Int                            @id @default(autoincrement())
  trainer            Trainer                        @relation(fields: [trainer_id], references: [id], onDelete: Cascade)
  trainer_id         String                         @db.Uuid
  step               TrainerCertificationStepEnum
  status             TrainerCertificationStatusEnum @default(NOT_STARTED)
  sessions_required  Int                            @default(1) @db.SmallInt
  sessions_completed Int                            @default(0) @db.SmallInt
  evaluator          User?                          @relation("TrainerCertificationEvaluator", fields: [evaluator_id], references: [id])
  evaluator_id       String?                        @db.Uuid
  notes              String?                        @db.Text
  completed_at       DateTime?                      @db.Timestamptz()
  created_at         DateTime                       @default(now()) @db.Timestamptz()
  updated_at         DateTime                       @default(now()) @updatedAt @db.Timestamptz()

  @@unique([trainer_id, step])
  @@map("trainer_certification_steps")
}

model TrainerAvailability {
  id         Int                           @id @default(autoincrement())
  trainer    Trainer                       @relation(fields: [trainer_id], references: [id], onDelete: Cascade)
  trainer_id String                        @db.Uuid
  period     DateTime                      @db.Date
  status     TrainerAvailabilityStatusEnum @default(AVAILABLE)
  notes      String?                       @db.VarChar()
  created_at DateTime                      @default(now()) @db.Timestamptz()
  updated_at DateTime                      @default(now()) @updatedAt @db.Timestamptz()

  @@unique([trainer_id, period])
  @@map("trainer_availabilities")
}

model TrainerAssignment {
  id                Int                       @id @default(autoincrement())
  pipeline          B2BPipeline               @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  pipeline_id       Int
  trainer           Trainer                   @relation(fields: [trainer_id], references: [id])
  trainer_id        String                    @db.Uuid
  session           B2BClassSession?          @relation(fields: [session_id], references: [id], onDelete: SetNull)
  session_id        Int?
  role              TrainerAssignmentRoleEnum @default(LEAD)
  session_date      DateTime?                 @db.Date
  participant_count Int?                      @db.SmallInt
  notes             String?                   @db.Text
  created_at        DateTime                  @default(now()) @db.Timestamptz()
  updated_at        DateTime                  @default(now()) @updatedAt @db.Timestamptz()
  evaluations       TrainerEvaluation[]

  @@map("trainer_assignments")
}

model TrainerEvaluation {
  id                     Int                @id @default(autoincrement())
  assignment             TrainerAssignment? @relation(fields: [assignment_id], references: [id], onDelete: SetNull)
  assignment_id          Int?
  trainer                Trainer            @relation(fields: [trainer_id], references: [id])
  trainer_id             String             @db.Uuid
  participant_rating_avg Decimal?           @db.Decimal(2, 1)
  self_report_submitted  Boolean            @default(false)
  reviewer               User?              @relation("TrainerEvaluationReviewer", fields: [reviewed_by], references: [id])
  reviewed_by            String?            @db.Uuid
  review_notes           String?            @db.Text
  evaluation_date        DateTime?          @db.Date
  created_at             DateTime           @default(now()) @db.Timestamptz()

  @@map("trainer_evaluations")
}

// B2B Class/Session

model B2BClass {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar()
  pipeline    B2BPipeline?      @relation(fields: [pipeline_id], references: [id], onDelete: SetNull)
  pipeline_id Int?
  description String?           @db.Text
  creator     User?             @relation("B2BClassCreator", fields: [created_by], references: [id])
  created_by  String?           @db.Uuid
  created_at  DateTime          @default(now()) @db.Timestamptz()
  updated_at  DateTime          @default(now()) @updatedAt @db.Timestamptz()
  sessions    B2BClassSession[]

  @@map("b2bc_classes")
}

model B2BClassSession {
  id            Int                          @id @default(autoincrement())
  class         B2BClass                     @relation(fields: [class_id], references: [id], onDelete: Cascade)
  class_id      Int
  name          String                       @db.VarChar()
  difficulty    B2BClassDifficultyEnum       @default(BEGINNER)
  min_quorum    Int                          @default(2) @db.SmallInt
  session_date  DateTime?                    @db.Date
  status        B2BClassSessionStatusEnum    @default(DRAFT)
  opened_at     DateTime?                    @db.Timestamptz()
  closed_at     DateTime?                    @db.Timestamptz()
  created_at    DateTime                     @default(now()) @db.Timestamptz()
  updated_at    DateTime                     @default(now()) @updatedAt @db.Timestamptz()
  applications  TrainerApplication[]
  notifications TrainerSessionNotification[]
  assignments   TrainerAssignment[]

  @@map("b2bc_sessions")
}

model TrainerApplication {
  id          Int                          @id @default(autoincrement())
  session     B2BClassSession              @relation(fields: [session_id], references: [id], onDelete: Cascade)
  session_id  Int
  trainer     Trainer                      @relation(fields: [trainer_id], references: [id])
  trainer_id  String                       @db.Uuid
  status      TrainerApplicationStatusEnum @default(APPLIED)
  notes       String?                      @db.Text
  reviewer    User?                        @relation("TrainerApplicationReviewer", fields: [reviewed_by], references: [id])
  reviewed_by String?                      @db.Uuid
  reviewed_at DateTime?                    @db.Timestamptz()
  created_at  DateTime                     @default(now()) @db.Timestamptz()
  updated_at  DateTime                     @default(now()) @updatedAt @db.Timestamptz()

  @@unique([session_id, trainer_id])
  @@map("trainer_applications")
}

model TrainerSessionNotification {
  id            Int                                  @id @default(autoincrement())
  session       B2BClassSession                      @relation(fields: [session_id], references: [id], onDelete: Cascade)
  session_id    Int
  trainer       Trainer                              @relation(fields: [trainer_id], references: [id])
  trainer_id    String                               @db.Uuid
  email         String                               @db.VarChar()
  status        TrainerSessionNotificationStatusEnum @default(SENT)
  error_message String?                              @db.Text
  sent_at       DateTime?                            @db.Timestamptz()
  created_at    DateTime                             @default(now()) @db.Timestamptz()

  @@unique([session_id, trainer_id])
  @@map("trainer_session_notifications")
}
